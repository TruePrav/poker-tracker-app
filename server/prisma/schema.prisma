generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  nickname  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries      TournamentEntry[]
  transactions Transaction[]
}

model Tournament {
  id               Int       @id @default(autoincrement())
  name             String
  date             DateTime  @default(now())
  buyInAmount      Int
  topUpAmount      Int       @default(0)
  topUpChips       Int       @default(0)
  startingChips    Int       @default(10000)
  buyInType        String    @default("FIXED")
  buyInPresets     String    @default("[]")
  status           String    @default("SETUP")
  currentLevel     Int       @default(1)
  timerSeconds     Int       @default(0)
  totalPrizePool   Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  finishedAt       DateTime?

  blindStructureId Int?
  blindStructure   BlindStructure? @relation(fields: [blindStructureId], references: [id])

  tables       TournamentTable[]
  entries      TournamentEntry[]
  transactions Transaction[]
}

model TournamentEntry {
  id             Int       @id @default(autoincrement())
  tournamentId   Int
  playerId       Int
  tableId        Int?
  seatNumber     Int?
  status         String    @default("REGISTERED")
  finishPosition Int?
  payout         Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  eliminatedAt   DateTime?

  tournament Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player           @relation(fields: [playerId], references: [id])
  table      TournamentTable? @relation(fields: [tableId], references: [id])

  @@unique([tournamentId, playerId])
  @@unique([tournamentId, tableId, seatNumber])
}

model TournamentTable {
  id           Int     @id @default(autoincrement())
  tournamentId Int
  tableNumber  Int
  tableName    String  @default("")
  maxSeats     Int     @default(9)
  isActive     Boolean @default(true)

  tournament Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  entries    TournamentEntry[]

  @@unique([tournamentId, tableNumber])
}

model Transaction {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  playerId     Int
  type         String
  amount       Int
  note         String?
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id])
}

model BlindStructure {
  id        Int      @id @default(autoincrement())
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  levels      BlindLevel[]
  tournaments Tournament[]
}

model BlindLevel {
  id               Int     @id @default(autoincrement())
  blindStructureId Int
  level            Int
  smallBlind       Int
  bigBlind         Int
  ante             Int     @default(0)
  durationMinutes  Int     @default(15)
  isBreak          Boolean @default(false)

  blindStructure BlindStructure @relation(fields: [blindStructureId], references: [id], onDelete: Cascade)

  @@unique([blindStructureId, level])
  @@index([blindStructureId, level])
}
